POSTGRES_DB=dq_test
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me
DQ_EXECUTOR_PASSWORD=change_me
DQ_APP_PASSWORD=change_me
RULE_EXECUTION_JITTER_SECONDS=120

# Optional notification settings. Leave blank to disable a channel.
SLACK_WEBHOOK_URL=
SMTP_SERVER=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_TIMEOUT_SECONDS=5
NOTIFICATION_HTTP_TIMEOUT_SECONDS=5
NOTIFICATION_EMAIL_FROM=alerts@dataqualitydaemon.local
ADMIN_EMAIL=

# Platform Intelligence settings.
# Get your Gemini API key from: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# Switch between "heuristic" (no API key needed) and "gemini" (uses Gemini 2.5 Flash).
RULE_SUGGESTION_BACKEND=heuristic

# Maximum rows to load when profiling a table.
PROFILING_ROW_LIMIT=100000

# Isolation Forest / LOF contamination, expected fraction of anomalies from 0.0 to 0.5.
ANOMALY_CONTAMINATION=0.05

# Gemini model.
GEMINI_MODEL=gemini-2.5-flash

# --- Intelligent Alerts (LLM Enrichment) ---
# Enable or disable LLM enrichment of violation batches.
LLM_ENABLED=false
# Model to use for summarization (e.g., llama3-8b-8192)
LLM_MODEL=llama3-8b-8192
# Groq API key for LLM summarization. Get one from: https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# Keep Prefect from starting a local ephemeral server.
PREFECT_SERVER_EPHEMERAL_ENABLED=false

# AI Rule Builder Feature Flag
VITE_AI_RULE_BUILDER_ENABLED=false
