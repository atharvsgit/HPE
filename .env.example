POSTGRES_DB=dq_test
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me
DQ_EXECUTOR_PASSWORD=change_me
DQ_APP_PASSWORD=change_me
RULE_EXECUTION_JITTER_SECONDS=120

# --- Platform Intelligence (Manjunath Patil) ---
# Get your Gemini API key from: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# Switch between "heuristic" (no API key needed) and "gemini" (uses Gemini 2.5 Flash)
RULE_SUGGESTION_BACKEND=heuristic

# Maximum rows to load when profiling a table (adjust for memory constraints)
PROFILING_ROW_LIMIT=100000

# Isolation Forest / LOF contamination (expected fraction of anomalies, 0.0–0.5)
ANOMALY_CONTAMINATION=0.05

# Gemini model (change to gemini-2.0-flash for faster/cheaper responses)
GEMINI_MODEL=gemini-2.5-flash

# Set to false to prevent Prefect from starting a local ephemeral server
PREFECT_SERVER_EPHEMERAL_ENABLED=false
