POSTGRES_DB=dq_test
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me
DQ_EXECUTOR_PASSWORD=change_me
DQ_APP_PASSWORD=change_me
RULE_EXECUTION_JITTER_SECONDS=120

# Optional email notification settings. Leave SMTP_SERVER blank to disable email.
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_TIMEOUT_SECONDS=5
NOTIFICATION_EMAIL_FROM=alerts@dataqualitydaemon.local
ADMIN_EMAIL=manjunathpatil3155@gmail.com

# LLM-assisted rule drafts. Use mock with no API key for local development.
LLM_PROVIDER=mock
LLM_MODEL=llama-3.1-8b-instant
LLM_API_KEY=
LLM_REQUEST_TIMEOUT_SECONDS=30
LLM_DRY_RUN_ENABLED=true

# Platform Intelligence (Manjunath Patil).
GEMINI_API_KEY=
RULE_SUGGESTION_BACKEND=heuristic
PROFILING_ROW_LIMIT=100000
ANOMALY_CONTAMINATION=0.05
GEMINI_MODEL=gemini-2.5-flash
PIPELINE_EXECUTION_JITTER_SECONDS=120
PREFECT_SERVER_ALLOW_EPHEMERAL_MODE=true
